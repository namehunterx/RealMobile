<!-- Простой скрипт для интерактива -->
<script>
    // Всё чётко: кнопки не ведут на сторонние сайты, только предупреждение о демо-режиме
    const buttons = document.querySelectorAll('.btn');
    buttons.forEach(btn => {
        btn.addEventListener('click', (e) => {
            e.preventDefault();
            alert('🔫 REAL MOBILE · Демо-версия интерфейса. Сервер Moscow полностью готов к бою!');
        });
    });

    // Добавим динамический счётчик онлайна (маленькая анимация)
    let onlineElement = document.querySelector('.stat-card:first-child .stat-number');
    if (onlineElement && onlineElement.innerText === '+850') {
        let count = 840;
        setInterval(() => {
            let change = Math.floor(Math.random() * 7) - 2; // -2 .. +4
            let newVal = Math.min(1120, Math.max(720, count + change));
            count = newVal;
            onlineElement.innerText = '+' + count;
        }, 19000);
    }
</script>
